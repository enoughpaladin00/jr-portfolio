---
import '../styles/global.css';
import Navbar from '../components/animations/Navbar';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Il mio portfolio digitale" } = Astro.props;
---

<!doctype html>
<html lang="it" class="scroll-smooth">
	<head>
    	<meta charset="UTF-8" />
    	<meta name="viewport" content="width=device-width" />
    	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    	<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    	<title>Jacopo Rossi | Software Engineer & AI Specialist</title>
    	<meta name="description" content="Portfolio di Jacopo Rossi, Ingegnere Informatico specializzato in Artificial Intelligence e Cybersecurity. Scopri i miei progetti e le mie competenze." />
    	<meta name="keywords" content="Jacopo Rossi, Ingegnere Informatico, Roma, Sapienza, Artificial Intelligence, Cybersecurity, Software Engineer, Sviluppatore" />
    	<meta name="author" content="Jacopo Rossi" />
		<meta name="google-site-verification" content="CtTq0UPHuVXP1Qy6H9YbyzOuXwupBoo7sJVT6NOResM" />  
		
		<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ws: wss: https://api.github.com; frame-src 'self' https://www.youtube.com;" />


    </head>

	<body class="bg-zinc-950 text-zinc-50 font-sans antialiased selection:bg-emerald-500 selection:text-zinc-950 min-h-screen flex flex-col">
		
		<Navbar client:load />

		<main class="flex-grow w-full max-w-5xl mx-auto px-6 pt-24 pb-12 md:py-32">
			<slot /> 
		</main>

		<Footer />

	</body>
</html>