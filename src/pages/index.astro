---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/animations/Hero.tsx';
import About from '../components/animations/About.tsx';
import ProjectGrid from '../components/animations/ProjectGrid.tsx';
import Contact from '../components/animations/Contact.tsx';

const githubUsername = 'enoughpaladin00';
let myProjects: Array<{
  id: number;
  title: string;
  description: string;
  tech: string[];
  github: string;
  link: string;
}> = [];

try {
  let page = 1;
  let keepFetching = true;
  let allRepos: any[] = [];

  while (keepFetching) {
    const response = await fetch(`https://api.github.com/users/${githubUsername}/repos?sort=updated&per_page=100&page=${page}`);
    
    if (response.ok) {
      const repos = await response.json();
      
      if (repos.length === 0) {
        keepFetching = false; 
      } else {
        allRepos = [...allRepos, ...repos];
        page++;
      }
    } else {
      console.error(`Errore API GitHub: ${response.status}`);
      keepFetching = false;
    }
  }

  myProjects = allRepos
    .filter((repo: any) => repo.fork === false) // Escludiamo i fork (Commenta se vuoi includerli)
    .map((repo: any) => ({
      id: repo.id,
      title: repo.name.replace(/[-_]/g, ' '), 
      description: repo.description || "Nessuna descrizione impostata su GitHub.",
      tech: repo.language ? [repo.language] : ["Codice vario"], 
      github: repo.html_url,
      link: repo.homepage || repo.html_url 
    }));

} catch (error) {
  console.error("Errore critico nel fetch da GitHub:", error);
}
---

<Layout title="Jacopo Rossi | Software Engineer">
	<Hero client:load />
	<About client:visible />
	<ProjectGrid projects={myProjects} client:visible />
	<Contact client:visible />
</Layout>