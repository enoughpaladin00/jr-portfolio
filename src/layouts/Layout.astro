---
import '../styles/global.css';
import Navbar from '../components/animations/Navbar.tsx';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Portfolio personale di un Software Engineer" } = Astro.props;
---

<!doctype html>
<html lang="it" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
		
		<title>{title}</title>
	</head>
	<body class="bg-zinc-950 text-zinc-50 font-sans antialiased selection:bg-emerald-500 selection:text-zinc-950 min-h-screen flex flex-col">
		
		<Navbar client:load />

		<main class="flex-grow w-full max-w-5xl mx-auto px-6 pt-24 pb-12 md:py-32">
			<slot /> 
		</main>

		<Footer />

	</body>
</html>